# Copy to .env and fill values for local development

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=auragate
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/auragate

# Redis
REDIS_URL=redis://redis:6379/0

# Neo4j
NEO4J_URL=bolt://neo4j:7687

# Twilio (leave blank to run in mock mode)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TO_PHONE_NUMBER=

# Bhashini API (example)
BHASHINI_API_KEY=

# App
LOG_LEVEL=INFO
