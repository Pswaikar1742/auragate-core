# Copy to .env and fill values for local development

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=auragate
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/auragate

# Redis
REDIS_URL=redis://redis:6379/0

# Neo4j
NEO4J_URL=bolt://neo4j:7687

# Twilio (leave blank to run in mock mode)
# If you want the backend to actually place IVR calls, set these to your Twilio credentials.
# `TO_PHONE_NUMBER` is a fallback recipient for escalation calls (E.164 format, e.g. +919876543210).
# If `TO_PHONE_NUMBER` is set, demo residents may be auto-seeded to that number for local testing.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TO_PHONE_NUMBER=

# Bhashini API (example)
BHASHINI_API_KEY=

# App
LOG_LEVEL=INFO
