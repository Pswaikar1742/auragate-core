# Example environment variables for Vercel / local development
# Copy these into your Vercel Project > Settings > Environment Variables

# URL of the deployed backend (no trailing slash)
NEXT_PUBLIC_BACKEND_URL=https://<your-backend-host>

# WebSocket base URL used by the frontend (wss:// or ws://)
NEXT_PUBLIC_WS_BASE_URL=wss://<your-backend-host>

# Optional: Supabase keys if frontend talks directly to Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<your-supabase-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
